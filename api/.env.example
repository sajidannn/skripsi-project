# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ─── DB Mode ─────────────────────────────────────────────────────────────────
# "single" → all tenants share one DB, queries use WHERE tenant_id = ?
# "multi"  → each tenant has its own DB, resolved from master DB via PGBouncer
DB_MODE=single

# ─── Single-DB settings (only needed when DB_MODE=single) ────────────────────
SINGLE_DSN=postgres://postgres:password@localhost:5432/pos_single?sslmode=disable

# ─── Multi-DB settings (only needed when DB_MODE=multi) ──────────────────────
MASTER_DSN=postgres://postgres:password@localhost:5432/pos_master?sslmode=disable
# Host / port where tenant DBs can be reached (usually PGBouncer endpoint)
TENANT_DB_HOST=localhost
TENANT_DB_PORT=6432

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
