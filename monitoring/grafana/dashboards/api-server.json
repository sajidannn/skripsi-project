{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "POS API Server (VM 1) — CPU, Memory, Network, Container metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Host (VM 1 OS-level)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node_exporter_api\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "title": "CPU Usage — API Server (VM 1)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node_exporter_api\"} - node_memory_MemAvailable_bytes{job=\"node_exporter_api\"}",
          "legendFormat": "Used Memory",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node_exporter_api\"}",
          "legendFormat": "Total Memory",
          "refId": "B"
        }
      ],
      "title": "Memory Usage — API Server (VM 1)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Container (pos-api Docker)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(container_cpu_usage_seconds_total{job=\"cadvisor_api\",name=~\"/?.?pos-api.*\"}[$__rate_interval]) * 100",
          "legendFormat": "{{name}} CPU %",
          "refId": "A"
        }
      ],
      "title": "Container CPU — pos-api",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "container_memory_working_set_bytes{job=\"cadvisor_api\",name=~\"/?.?pos-api.*\"}",
          "legendFormat": "{{name}} Memory (WSS)",
          "refId": "A"
        }
      ],
      "title": "Container Memory — pos-api",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_network_receive_bytes_total{job=\"node_exporter_api\",device!~\"lo|docker.*|br.*\"}[$__rate_interval])",
          "legendFormat": "RX — {{device}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_network_transmit_bytes_total{job=\"node_exporter_api\",device!~\"lo|docker.*|br.*\"}[$__rate_interval])",
          "legendFormat": "TX — {{device}}",
          "refId": "B"
        }
      ],
      "title": "Network I/O — API Server (VM 1)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["pos", "api", "vm1"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Jakarta",
  "title": "POS — API Server (VM 1)",
  "uid": "pos-api-server",
  "version": 1
}
