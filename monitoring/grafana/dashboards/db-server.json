    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "percent",
          "min": 0,
