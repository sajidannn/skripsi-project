{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "POS DB Server (VM 2) — CPU, Memory, Disk I/O, PostgreSQL metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Host (VM 2 OS-level)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node_exporter_db\",mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "title": "CPU Usage — DB Server (VM 2)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node_exporter_db\"} - node_memory_MemAvailable_bytes{job=\"node_exporter_db\"}",
          "legendFormat": "Used Memory",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node_exporter_db\"}",
          "legendFormat": "Total Memory",
          "refId": "B"
        }
      ],
      "title": "Memory Usage — DB Server (VM 2)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 - (node_memory_MemAvailable_bytes{job=\"node_exporter_db\"} / node_memory_MemTotal_bytes{job=\"node_exporter_db\"} * 100)",
          "legendFormat": "Memory Usage %",
          "refId": "A"
        }
      ],
      "title": "Memory Usage % — DB Server (VM 2)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Disk I/O (sesuai proposal Tabel 3.9)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_disk_read_bytes_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval])",
          "legendFormat": "Read — {{device}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_disk_written_bytes_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval])",
          "legendFormat": "Write — {{device}}",
          "refId": "B"
        }
      ],
      "title": "Disk I/O Throughput — DB Server (VM 2)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_disk_read_time_seconds_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval]) / rate(node_disk_reads_completed_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval]) * 1000",
          "legendFormat": "Read Latency — {{device}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(node_disk_write_time_seconds_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval]) / rate(node_disk_writes_completed_total{job=\"node_exporter_db\",device!~\"sr.*|loop.*\"}[$__rate_interval]) * 1000",
          "legendFormat": "Write Latency — {{device}}",
          "refId": "B"
        }
      ],
      "title": "Disk Latency — DB Server (VM 2)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "PostgreSQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "pg_stat_activity_count{job=\"postgres_exporter\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ],
      "title": "PostgreSQL Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(pg_stat_database_tup_inserted{job=\"postgres_exporter\"}[$__rate_interval])",
          "legendFormat": "Inserts/s — {{datname}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(pg_stat_database_tup_updated{job=\"postgres_exporter\"}[$__rate_interval])",
          "legendFormat": "Updates/s — {{datname}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(pg_stat_database_tup_returned{job=\"postgres_exporter\"}[$__rate_interval])",
          "legendFormat": "Reads/s — {{datname}}",
          "refId": "C"
        }
      ],
      "title": "PostgreSQL Tuples Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "pg_locks_count{job=\"postgres_exporter\"}",
          "legendFormat": "Locks — {{mode}}",
          "refId": "A"
        }
      ],
      "title": "PostgreSQL Lock Count",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres_exporter\"}[$__rate_interval])",
          "legendFormat": "Commits/s — {{datname}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres_exporter\"}[$__rate_interval])",
          "legendFormat": "Rollbacks/s — {{datname}}",
          "refId": "B"
        }
      ],
      "title": "PostgreSQL Transaction Rate (Commit/Rollback)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 * (sum by (datname) (rate(pg_stat_database_blks_hit{job=\"postgres_exporter\"}[$__rate_interval])) / (sum by (datname) (rate(pg_stat_database_blks_hit{job=\"postgres_exporter\"}[$__rate_interval])) + sum by (datname) (rate(pg_stat_database_blks_read{job=\"postgres_exporter\"}[$__rate_interval])) > 0))",
          "legendFormat": "Cache Hit — {{datname}}",
          "refId": "A"
        }
      ],
      "title": "PostgreSQL Cache Hit Ratio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
